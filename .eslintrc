{
  "env": {
    "jest/globals": true,
    "browser": true,
    "es6": true
  },
  "extends": [
    "groupon"
  ],
  "plugins": ["jest"],
  "rules": {
    "node/no-unsupported-features/es-syntax": 0,
    "import/no-extraneous-dependencies": 0
  },
  "parserOptions": {
    "sourceType": "module"
  },
  "settings": {
    "import/resolver": {
      "node": {
        "extensions": [".js", ".ts"]
      }
    },
    "node": {
      "tryExtensions": [".js", ".ts", ".json", ".node"]
    }
  },
  "overrides": [
    {
      "files": ["*.ts"],
      "parser": "@typescript-eslint/parser",
      "plugins": ["@typescript-eslint"],
      "rules": {
        "no-undef": 0,
        "no-unused-vars": 0
      }
    }
  ]
}
